# AI-Powered Dashboards — environment variable reference.
# Copy to `.env` for local dev. Hugging Face Space variables/secrets mirror this.

# ─── Auth (Clerk) ──────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=
# Backend falls back to this if CLERK_PUBLISHABLE_KEY is unset:
VITE_CLERK_PUBLISHABLE_KEY=
# Anonymous guest access. true (default) = open guest mode; set false to make
# the app invite-only — every endpoint then requires a valid Clerk token.
# Pair with a Clerk restricted/allow-listed sign-up to limit access to a
# specific tester (e.g. a trial prospect).
GUEST_MODE_ENABLED=true

# ─── Pipeline tuning ───────────────────────────────────────
DEBUG=false
MAX_ROWS=500000
MAX_COLS=50
MAX_CATEGORIES=10
MAX_CHARTS=20
KPI_TOP_K=10
MIN_VARIABILITY_THRESHOLD=0.01
MIN_UNIQUE_RATIO=0.01
MAX_UNIQUE_RATIO=0.9
MIN_CORRELATION=0.5
MIN_VARIANCE=0.001
MEMORY_LIMIT_MB=1000
TIMEOUT_SECONDS=600
UNIQUENESS_CUTOFF=0.95
AVG_LENGTH_CUTOFF=30
MIN_DATE=1900
MAX_DATE=2100

# ─── HTTP ──────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000

# ─── Persistence ───────────────────────────────────────────
# Any SQLAlchemy URL. Default = local SQLite file. Prod example:
#   postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./_local/dashboards.db
# Dashboard rows expire this many seconds after last write (default 24h):
DASHBOARD_TTL_SECONDS=86400
# Optional Redis read-through cache. Leave blank to disable.
# ALSO used as the Arq broker when JOB_QUEUE_ENABLED=true.
REDIS_URL=

# ─── Async analysis jobs (Phase 10 S10.1) ──────────────────
# false (default) → in-process asyncio job. Fixes the auth-expiry 401 and the
#   blocked request with NO deployment change. In-flight jobs lost on restart.
#   This is the Hugging Face setting.
# true → out-of-process Arq worker (production-correct, durable). Requires
#   REDIS_URL and a separate worker process:  arq src.jobs.worker.WorkerSettings
JOB_QUEUE_ENABLED=false
# Where uploads are spooled so a separate worker can read them (blank = OS temp).
JOB_SPOOL_DIR=
JOB_TTL_SECONDS=86400
JOB_STREAM_POLL_SECONDS=0.5
# Worker tuning (only when JOB_QUEUE_ENABLED=true):
JOB_WORKER_MAX_JOBS=2
JOB_TIMEOUT_SECONDS=3600

# ─── Observability ─────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE_HANDLERS=false

# OpenTelemetry — set both to enable; leave blank to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-powered-dashboards

# Sentry — set DSN to enable; leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# ─── Kaggle ingestion (optional) ───────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=
